          "lookup_file": "partCapability",
          "lookup_key_col_idx": 1,
          "target_col_idx": 8,
          "step_label": "Lookup QPA",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "MTBUR for IP",
          "type": "vlookup",
          "lookup_file": "partCapability",
          "lookup_key_col_idx": 1,
          "target_col_idx": 7,
          "step_label": "Lookup MTBUR for IP",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "RRI",
          "type": "vlookup",
          "lookup_file": "partNumbers",
          "lookup_key_col_idx": 0,
          "target_col_idx": 2,
          "step_label": "Lookup RRI",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "Buy Price (USD)",
          "type": "vlookup",
          "lookup_file": "partNumbers",
          "lookup_key_col_idx": 0,
          "target_col_idx": 3,
          "step_label": "Lookup Buy Price",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "Aircraft Count",
          "type": "vlookup",
          "lookup_file": "partNumbers",
          "lookup_key_col_idx": 0,
          "target_col_idx": 4,
          "step_label": "Lookup Aircraft Count",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "TAT",
          "type": "vlookup",
          "lookup_file": "partCapability",
          "lookup_key_col_idx": 1,
          "target_col_idx": 17,
          "formula_suffix": "+11+7",
          "step_label": "Calculate TAT",
          "agent": "TAT Agent",
          "tool": "CrossRef_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Annual Demand - Dann",
          "type": "expression",
          "formula_template": "{B}*{E}*{I}/({F}*POWER(10,{G}))",
          "step_label": "Calculate Annual Demand",
          "agent": "Demand Calculation Agent",
          "tool": "Arithmetic_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Expected Demand during Re-supply Time",
          "type": "expression",
          "formula_template": "ROUND({K}*{J}/365, 2)",
          "step_label": "Calculate Expected Demand",
          "agent": "Demand Calculation Agent",
          "tool": "Arithmetic_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Protection Level (P.L)",
          "type": "vlookup",
          "lookup_file": "parameters",
          "search_key_col_idx": 3,
          "manual_range": {
            "start_row": 9,
            "end_row": 11,
            "key_col_idx": 1,
            "val_col_idx": 2
          },
          "step_label": "Lookup Protection Level",
          "agent": "Policy Agent",
          "tool": "CrossRef_Engine",
          "phase": "Modeling"
        },
        {
          "header": "MAD",
          "type": "vlookup",
          "lookup_file": "parameters",
          "search_key_col_idx": 3,
          "manual_range": {
            "start_row": 9,
            "end_row": 11,
            "key_col_idx": 1,
            "val_col_idx": 3
          },
          "step_label": "Lookup MAD",
          "agent": "Policy Agent",
          "tool": "CrossRef_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Does part qualify as spare?",
          "type": "expression",
          "formula_template": "IF({L}>{N}, \"Yes\", \"No\")",
          "step_label": "Calculate Spare Qualification",
          "agent": "Policy Agent",
          "tool": "Logic_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Qty",
          "type": "poisson_spare",
          "lookup_file": "parameters",
          "manual_range": {
            "start_row": 5,
            "end_row": 7,
            "key_col_idx": 1,
            "val_col_idx": 2
          },
          "lambda_col": "L",
          "target_col": "N",
          "search_key_col": "D",
          "manual_formula": "LET(lambda;L{i};target;M{i}-VLOOKUP(D{i};Parameters!$F$1:$G$4;2;FALSE);n;SEQUENCE(100;1;0;1);INDEX(n;MATCH(TRUE;ROUND(POISSON(n;lambda;TRUE);2)>=target;0)))",
          "step_label": "Calculate Recommended Qty",
          "agent": "Poisson Provisioning Agent",
          "tool": "Poisson_Engine",
          "phase": "Modeling"
        },
        {
          "header": "Actual P.L.",
          "type": "expression",
          "formula_template": "POISSON({P}, {L}, TRUE)",
          "step_label": "Calculate Actual P.L.",
          "agent": "Validation Agent",
          "tool": "Poisson_Engine",
          "phase": "Validation"
        },
        {
          "header": "Deviation",
          "type": "expression",
          "formula_template": "ROUND({M}-{Q}, 2)",
          "step_label": "Calculate Deviation",
          "agent": "Validation Agent",
          "tool": "Arithmetic_Engine",
          "phase": "Validation"
        },
        {
          "header": "Calculation Status",
          "type": "expression",
          "formula_template": "IF({R}>VLOOKUP({D}, Parameters!$F$1:$G$4, 2, FALSE), \"Re-Calculate\", \"OK\")",
          "step_label": "Final Status Check",
          "agent": "Validation Agent",
          "tool": "Logic_Engine",
          "phase": "Validation"
        },
        {
          "header": "ESS1 Arising TRT",
          "type": "expression",
          "formula_template": "IF({D}=1, {L}, \" \")",
          "step_label": "Calculate ESS1 Arising TRT",
          "agent": "Policy Agent",
          "tool": "Logic_Engine",
          "phase": "Validation"
        },
        {
          "header": "ESS2 Arising TRT",
          "type": "expression",
          "formula_template": "IF({D}=2, {L}, \" \")",
          "step_label": "Calculate ESS2 Arising TRT",
          "agent": "Policy Agent",
          "tool": "Logic_Engine",
          "phase": "Validation"
        },
        {
          "header": "ESS3 Arising TRT",
