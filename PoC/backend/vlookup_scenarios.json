        },
        {
          "header": "Annual FH",
          "type": "vlookup",
          "lookup_file": "partNumbers",
          "lookup_key_col_idx": 0,
          "target_col_idx": 1,
          "step_label": "Lookup Annual FH",
          "agent": "Data Mapping Agent",
          "tool": "CrossRef_Engine",
          "phase": "Planning"
        },
        {
          "header": "SPC",
          "type": "vlookup",
