          "formula_template": "IF({D}=3, {L}, \" \")",
          "step_label": "Calculate ESS3 Arising TRT",
          "agent": "Policy Agent",
          "tool": "Logic_Engine",
          "phase": "Validation"
        },
        {
          "header": "ESS1 Actual TRT Demand",
          "type": "expression",
          "formula_template": "IF({D}=1, {L}*{Q}, \" \")",
          "step_label": "Calculate ESS1 Actual TRT Demand",
          "agent": "Policy Agent",
          "tool": "Logic_Engine",
          "phase": "Validation"
        },
        {
